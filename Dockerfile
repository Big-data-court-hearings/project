# ============================================================
# Base image
# ============================================================

FROM python:3.11-slim

# ============================================================
# Working directory
# ============================================================

WORKDIR /app

# ============================================================
# Copy requirements
# ============================================================

COPY requirements.txt .

# ============================================================
# Install dependencies
# ============================================================

RUN pip install --no-cache-dir -r requirements.txt

# ============================================================
# Copy project files
# ============================================================

COPY . .

# ============================================================
# Streamlit configuration
# ============================================================

EXPOSE 8501

# ============================================================
# Launch dashboard
# ============================================================

CMD ["streamlit", "run", "dashboard/app.py", "--server.address=0.0.0.0"]